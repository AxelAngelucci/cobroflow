# =============================================
# CobroFlow Backend - Environment Variables
# =============================================

# Application
APP_NAME=CobroFlow
APP_VERSION=0.1.0
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# ---- Database ----
# Local development (TCP):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password

# Cloud Run with Cloud SQL Auth Proxy (Unix socket):
# DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=from-secret-manager

# GCP
GCP_PROJECT_ID=cobro-flow
GCP_LOCATION=us-central1

# Cloud Tasks
CLOUD_RUN_SERVICE_URL=https://cobroflow-backend-432329306904.us-central1.run.app
CLOUD_TASKS_QUEUE_MESSAGES=message-sending
CLOUD_TASKS_QUEUE_CAMPAIGNS=campaign-evaluation
CLOUD_TASKS_SERVICE_ACCOUNT=cobroflow-tasks@cobro-flow.iam.gserviceaccount.com

# Vertex AI
VERTEX_FLASH_MODEL=gemini-2.0-flash-001
VERTEX_PRO_MODEL=gemini-2.5-pro-preview-06-05
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_LOCAL_VECTOR_STORE=true

# Security - CHANGE IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS (JSON array format)
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]
# Production: CORS_ORIGINS=["https://app.cobroflow.com"]
